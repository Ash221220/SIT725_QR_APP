        {
          "name": "POST /api/auth/register — main owner (201)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Main Owner\",\n  \"email\": \"{{ownerEmail}}\",\n  \"password\": \"{{ownerPassword}}\",\n  \"pendingRestaurantName\": \"Main Bistro\",\n  \"pendingRestaurantAddress\": \"42 Collins St Melbourne\",\n  \"pendingRestaurantPhone\": \"+61 412 000 001\",\n  \"pendingRestaurantEmail\": \"main.bistro@example.com\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Response has success:true and user object', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.expect(json.user).to.be.an('object');",
                  "  pm.expect(json.user.status).to.equal('pending');",
                  "  pm.expect(json.user).to.not.have.property('password');",
                  "});",
                  "const json = pm.response.json();",
                  "if (json.user && json.user._id) {",
                  "  pm.collectionVariables.set('pendingOwnerId', json.user._id);",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
